from flask import Flask, request

app = Flask(__name__)

# This creates the URL path: /capture
@app.route('/capture')
def capture():
    # It looks for anything after '?msg=' in the URL
    user_data = request.args.get('msg', 'No data')
    
    # This saves the data to your log file
    with open("my_secrets.txt", "a") as f:
        f.write(f"Web Entry: {user_data}\n")
        
    return f"Data '{user_data}' recorded successfully!"

if __name__ == '__main__':
    # Starts the server on port 5000
    app.run(host='0.0.0.0', port=5000)
